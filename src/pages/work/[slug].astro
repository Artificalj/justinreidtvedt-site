---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import VideoPlayer from "../../components/VideoPlayer.astro";
import BillboardShowcase from "../../components/BillboardShowcase.astro";
import ProjectNav from "../../components/ProjectNav.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const byOrder = (a: (typeof projects)[number], b: (typeof projects)[number]) => a.data.order - b.data.order;

  // Prev/next stays within the same credit group as the site's own listing
  // pages (Director grid vs. Producer-only grid) so a project Justin only
  // produced never sits in a sequence between projects he directed.
  const directorSequence = projects.filter((p) => p.data.roles.includes("Director")).sort(byOrder);
  const producerOnlySequence = projects
    .filter((p) => p.data.roles.includes("Producer") && !p.data.roles.includes("Director"))
    .sort(byOrder);

  return projects.map((project) => {
    const sequence = project.data.roles.includes("Director") ? directorSequence : producerOnlySequence;
    const index = sequence.findIndex((p) => p.id === project.id);
    return {
      params: { slug: project.id },
      props: {
        project,
        prev: sequence[(index - 1 + sequence.length) % sequence.length],
        next: sequence[(index + 1) % sequence.length],
      },
    };
  });
}

const { project, prev, next } = Astro.props;
const { title, client, roles, director, additionalProducers } = project.data;

const directorName = director ?? (roles.includes("Director") ? "Justin Reid Tvedt" : undefined);
const producerNames = roles.includes("Producer")
  ? ["Justin Reid Tvedt", ...(additionalProducers ?? [])]
  : additionalProducers ?? [];
const hasCredits = Boolean(directorName) || producerNames.length > 0;
---

<Layout title={title}>
  <div class="mx-auto max-w-5xl px-4 py-6 sm:px-8">
    <VideoPlayer src={project.data.fullVideoSrc ?? project.data.videoSrc} poster={project.data.thumbnail} title={title} />
    <div class="pt-4">
      <h1 class="font-(family-name:--font-display) text-2xl">
        {client ? `${client}: ${title}` : title}
      </h1>
      {hasCredits ? (
        <div class="flex flex-col gap-0.5">
          {directorName && (
            <p class="font-(family-name:--font-mono) text-xs text-(--color-muted)">Directed by {directorName}</p>
          )}
          {producerNames.length > 0 && (
            <p class="font-(family-name:--font-mono) text-xs text-(--color-muted)">Produced by {producerNames.join(", ")}</p>
          )}
          {roles.includes("Editor") && (
            <p class="font-(family-name:--font-mono) text-xs text-(--color-muted)">Edited by Justin Reid Tvedt</p>
          )}
        </div>
      ) : (
        <p class="font-(family-name:--font-mono) text-xs text-(--color-muted)">Roles: {roles.join(", ")}</p>
      )}
    </div>
  </div>

  {project.data.heroFit === "contain" && <BillboardShowcase project={project} />}

  <ProjectNav prev={prev} next={next} />
</Layout>
