---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/paths";

interface Props {
  reel: CollectionEntry<"projects">[];
  role?: string;
}

const { reel, role = "DIRECTOR" } = Astro.props;
const reelData = reel.map((p) => ({
  src: withBase(p.data.heroSrc ?? p.data.videoSrc),
  poster: withBase(p.data.heroPoster ?? p.data.thumbnail),
  title: p.data.title,
  format: p.data.format ?? null,
  objectPosition: p.data.heroObjectPosition ?? "center",
  objectFit: p.data.heroFit ?? "cover",
  frame: p.data.heroFit === "contain" ? "paper" : "void",
}));
const first = reelData[0];
const firstLabel = first.format
  ? `${first.format.toUpperCase()} — ${first.title.toUpperCase()}`
  : first.title.toUpperCase();
---

<section
  class="hero relative h-[78vh] min-h-[420px] w-full overflow-hidden transition-colors duration-700"
  data-hero
  data-frame={first.frame}
>
  <div class="absolute -inset-2" data-hero-parallax style="transform: translate(var(--hero-px, 0px), var(--hero-py, 0px));">
    <video
      class="hero-layer absolute inset-0 h-full w-full opacity-90 transition-opacity duration-500 ease-in-out"
      data-layer="a"
      src={first.src}
      poster={first.poster}
      style={`object-fit: ${first.objectFit}; object-position: ${first.objectPosition}; background-color: var(${first.frame === "paper" ? "--color-paper" : "--color-void"});`}
      autoplay
      muted
      loop
      playsinline
    ></video>
    <video
      class="hero-layer absolute inset-0 h-full w-full opacity-0 transition-opacity duration-500 ease-in-out"
      data-layer="b"
      muted
      loop
      playsinline
    ></video>
  </div>

  <div class="hero-dip absolute inset-0 opacity-0 transition-opacity duration-500 ease-in-out" data-hero-dip></div>

  <div class="hero-scrim absolute inset-0"></div>

  <div class="absolute inset-0 flex flex-col items-start justify-end px-4 pb-10 sm:px-8">
    <h1
      class="hero-title font-(family-name:--font-wordmark) text-[clamp(2.5rem,8vw,6.5rem)] italic leading-[0.95] tracking-wide"
    >
      Justın Reıd Tvedt
    </h1>
    <div
      class="hero-meta mt-3 flex flex-wrap items-center gap-3 font-(family-name:--font-mono) text-xs tracking-[0.2em]"
    >
      <span>{role}</span>
      <span class="hero-meta-muted">—</span>
      <span data-hero-label>{firstLabel}</span>
    </div>
  </div>

  <script type="application/json" data-reel-json set:html={JSON.stringify(reelData)}></script>
</section>

<style>
  .hero {
    background-color: var(--color-void);
  }
  .hero[data-frame="paper"] {
    background-color: var(--color-paper);
  }

  .hero-dip {
    background-color: var(--color-void);
  }

  .hero-scrim {
    background-image: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-void) 80%, transparent),
      transparent,
      color-mix(in srgb, var(--color-void) 20%, transparent)
    );
    transition: background-image 0.7s ease-out;
  }
  .hero[data-frame="paper"] .hero-scrim {
    background-image: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-paper) 90%, transparent),
      transparent,
      transparent
    );
  }

  .hero-title,
  .hero-meta {
    color: white;
    transition: color 0.7s ease-out;
  }
  .hero-meta-muted {
    color: rgb(255 255 255 / 0.3);
  }
  .hero-meta {
    color: rgb(255 255 255 / 0.7);
  }
  .hero[data-frame="paper"] .hero-title,
  .hero[data-frame="paper"] .hero-meta {
    color: var(--color-void);
  }
  .hero[data-frame="paper"] .hero-meta {
    color: color-mix(in srgb, var(--color-void) 70%, transparent);
  }
  .hero[data-frame="paper"] .hero-meta-muted {
    color: color-mix(in srgb, var(--color-void) 30%, transparent);
  }
</style>

<script>
  interface ReelItem {
    src: string;
    poster: string;
    title: string;
    format: string | null;
    objectPosition: string;
    objectFit: string;
    frame: string;
  }

  function initHeroParallax(root: HTMLElement) {
    const parallax = root.querySelector<HTMLElement>("[data-hero-parallax]");
    if (!parallax) return () => {};

    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let raf = 0;

    const onMouseMove = (e: MouseEvent) => {
      const rect = root.getBoundingClientRect();
      const relX = (e.clientX - rect.left) / rect.width - 0.5;
      const relY = (e.clientY - rect.top) / rect.height - 0.5;
      // Deliberately tiny range — a whisper of drift, not a display effect.
      targetX = relX * -6;
      targetY = relY * -4;
    };

    function tick() {
      currentX += (targetX - currentX) * 0.04;
      currentY += (targetY - currentY) * 0.04;
      parallax.style.setProperty("--hero-px", `${currentX.toFixed(2)}px`);
      parallax.style.setProperty("--hero-py", `${currentY.toFixed(2)}px`);
      raf = requestAnimationFrame(tick);
    }

    root.addEventListener("mousemove", onMouseMove);
    raf = requestAnimationFrame(tick);

    return () => {
      root.removeEventListener("mousemove", onMouseMove);
      cancelAnimationFrame(raf);
    };
  }

  // Source cuts often end on a broadcast fade-to-black. Restart each loop just
  // before the true end so that tail never gets a chance to render.
  const LOOP_FADE_GUARD = 0.4;

  function installSeamlessLoop(video: HTMLVideoElement) {
    video.addEventListener("timeupdate", () => {
      if (video.duration && video.currentTime >= video.duration - LOOP_FADE_GUARD) {
        video.currentTime = 0;
      }
    });
  }

  // Cutting through a solid dip (rather than dissolving two clips directly
  // into each other) hides the letterbox/frame-color change between clips
  // and keeps every transition looking identical regardless of what's
  // adjacent. DIP_HOLD_MS is a floor, not a fixed delay — the incoming clip
  // preloads in parallel, so a slow network extends the black hold instead
  // of revealing a half-loaded frame.
  const DIP_HOLD_MS = 450;

  function initHero(root: HTMLElement) {
    const json = root.querySelector<HTMLScriptElement>("[data-reel-json]")!;
    const reel: ReelItem[] = JSON.parse(json.textContent || "[]");
    const layerA = root.querySelector<HTMLVideoElement>('[data-layer="a"]')!;
    const layerB = root.querySelector<HTMLVideoElement>('[data-layer="b"]')!;
    const dip = root.querySelector<HTMLElement>("[data-hero-dip]")!;
    const label = root.querySelector<HTMLElement>("[data-hero-label]")!;
    const cleanupParallax = initHeroParallax(root);
    installSeamlessLoop(layerA);
    installSeamlessLoop(layerB);

    let activeLayer = layerA;
    let idleLayer = layerB;
    let idleIndex = 0;
    let idleTimer: ReturnType<typeof setInterval> | null = null;
    let lockedCategory: string | null = null;
    let lockedItem: ReelItem | null = null;
    let isPreviewing = false;
    let showToken = 0;

    function showItem(item: ReelItem) {
      const token = ++showToken;
      const incoming = idleLayer;
      const outgoing = activeLayer;
      [activeLayer, idleLayer] = [incoming, outgoing];

      dip.classList.remove("opacity-0");
      outgoing.classList.add("opacity-0");
      root.dataset.frame = "void";

      incoming.poster = item.poster;
      incoming.src = item.src;
      incoming.style.objectFit = item.objectFit ?? "cover";
      incoming.style.objectPosition = item.objectPosition ?? "center";
      incoming.style.backgroundColor = `var(${item.frame === "paper" ? "--color-paper" : "--color-void"})`;
      incoming.load();
      incoming.play().catch(() => {});

      let dipDone = false;
      let clipReady = false;

      const reveal = () => {
        if (!dipDone || !clipReady || token !== showToken) return;
        incoming.removeEventListener("canplay", onCanPlay);
        root.dataset.frame = item.frame ?? "void";
        incoming.classList.remove("opacity-0");
        dip.classList.add("opacity-0");
        label.textContent = item.format
          ? `${item.format.toUpperCase()} — ${item.title.toUpperCase()}`
          : item.title.toUpperCase();
      };

      const onCanPlay = () => {
        clipReady = true;
        reveal();
      };

      setTimeout(() => {
        dipDone = true;
        reveal();
      }, DIP_HOLD_MS);
      incoming.addEventListener("canplay", onCanPlay);
    }

    function startIdleCycle() {
      stopIdleCycle();
      idleTimer = setInterval(() => {
        idleIndex = (idleIndex + 1) % reel.length;
        showItem(reel[idleIndex]);
      }, 6000);
    }

    function stopIdleCycle() {
      if (idleTimer) clearInterval(idleTimer);
      idleTimer = null;
    }

    function resolveIdleState() {
      if (lockedItem) {
        showItem(lockedItem);
        stopIdleCycle();
      } else {
        startIdleCycle();
      }
    }

    const onPreview = ((e: CustomEvent<ReelItem>) => {
      isPreviewing = true;
      stopIdleCycle();
      showItem(e.detail);
    }) as EventListener;

    const onPreviewEnd = (() => {
      isPreviewing = false;
      resolveIdleState();
    }) as EventListener;

    const onLock = ((e: CustomEvent<{ category: string; item: ReelItem }>) => {
      const { category, item } = e.detail;
      lockedCategory = category;
      lockedItem = item;
      document.dispatchEvent(new CustomEvent("hero:lock-changed", { detail: { category: lockedCategory } }));
      if (!isPreviewing) resolveIdleState();
    }) as EventListener;

    const onUnlock = (() => {
      lockedCategory = null;
      lockedItem = null;
      document.dispatchEvent(new CustomEvent("hero:lock-changed", { detail: { category: null } }));
      if (!isPreviewing) resolveIdleState();
    }) as EventListener;

    document.addEventListener("hero:preview", onPreview);
    document.addEventListener("hero:preview-end", onPreviewEnd);
    document.addEventListener("hero:lock", onLock);
    document.addEventListener("hero:unlock", onUnlock);

    startIdleCycle();

    return () => {
      stopIdleCycle();
      document.removeEventListener("hero:preview", onPreview);
      document.removeEventListener("hero:preview-end", onPreviewEnd);
      document.removeEventListener("hero:lock", onLock);
      document.removeEventListener("hero:unlock", onUnlock);
      cleanupParallax();
    };
  }

  let cleanup: (() => void) | null = null;

  document.addEventListener("astro:before-swap", () => {
    if (cleanup) cleanup();
    cleanup = null;
  });

  document.addEventListener("astro:page-load", () => {
    const root = document.querySelector<HTMLElement>("[data-hero]");
    if (!root) return;
    cleanup = initHero(root);
  });
</script>
